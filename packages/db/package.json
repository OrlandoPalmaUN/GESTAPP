{
  "name": "@antigravity/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/tenant-migrations && cp tenant-migrations/*.sql dist/tenant-migrations/",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "studio": "prisma studio",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "kysely": "^0.29.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@antigravity/config": "workspace:*",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.7",
    "prisma": "^7.8.0",
    "typescript": "^5.6.3"
  }
}

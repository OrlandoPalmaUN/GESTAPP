{
  "name": "antigravity",
  "private": true,
  "engines": {
    "node": "20"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "node apps/api/dist/server.js",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "migrate:tenants": "tsx scripts/migrate-tenants.ts",
    "seed:superadmin": "tsx scripts/seed-superadmin.ts"
  },
  "dependencies": {
    "@antigravity/db": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv": "^16.4.7",
    "eslint": "^10.4.1",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1"
  }
}
